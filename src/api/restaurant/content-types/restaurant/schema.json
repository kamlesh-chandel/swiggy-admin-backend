{
  "kind": "collectionType",
  "collectionName": "restaurants",
  "info": {
    "singularName": "restaurant",
    "pluralName": "restaurants",
    "displayName": "restaurant"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "address": {
      "type": "string",
      "required": true
    },
    "city": {
      "type": "string",
      "required": true
    },
    "rating": {
      "type": "integer",
      "required": true
    },
    "isActive": {
      "type": "boolean",
      "required": false,
      "default": true
    },
    "food_items": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::food-item.food-item",
      "mappedBy": "restaurant"
    },
    "orders": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::order.order",
      "mappedBy": "restaurant"
    }
  }
}
