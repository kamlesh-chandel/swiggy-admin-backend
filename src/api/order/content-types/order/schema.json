{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "order"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "orderNumber": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "currentStatus": {
      "type": "enumeration",
      "enum": [
        "Pending",
        "Confirmed",
        "Preparing",
        "Delivered",
        "Cancelled"
      ]
    },
    "totalAmount": {
      "type": "decimal",
      "required": true
    },
    "customer": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::customer.customer",
      "inversedBy": "orders"
    },
    "restaurant": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::restaurant.restaurant",
      "inversedBy": "orders"
    },
    "food_items": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::food-item.food-item",
      "inversedBy": "orders"
    }
  }
}
