{
  "kind": "collectionType",
  "collectionName": "admins_users",
  "info": {
    "singularName": "admin-user",
    "pluralName": "admins-users",
    "displayName": "admin-user"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "email": {
      "type": "email",
      "required": true,
      "unique": true
    },
    "password": {
      "type": "password",
      "required": true
    },
    "role": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "super_admin",
        "admin"
      ]
    }
  }
}
